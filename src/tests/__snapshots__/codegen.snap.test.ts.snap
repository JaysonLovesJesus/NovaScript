exports[`codegen snapshots > compiles option matching 1`] = `
"// Prelude
function Some(value) { return { tag: "Some", value }; }
const None = { tag: "None" };

function find(arr, target) {
  let i = 0;
  while ((i < arr.length)) {
    if ((arr[i] == target)) {
      return Some(i);
    }
    (i = (i + 1));
  }
  return None;
}
"
`;

