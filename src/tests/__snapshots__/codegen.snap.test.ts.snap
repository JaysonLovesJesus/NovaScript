exports[`codegen snapshots > compiles fib 1`] = `
"function fib(n) {
  if ((n < 2)) {
    return n;
  } else {
    return (fib((n - 1)) + fib((n - 2)));
  }
}

function main() {
  const result = fib(10);
  console.log(result);
}

main();"
`;

